{
  "name": "@rsbuild/plugin-check-syntax",
  "version": "2.0.0",
  "repository": "https://github.com/rstackjs/rsbuild-plugin-check-syntax",
  "homepage": "https://github.com/rstackjs/rsbuild-plugin-check-syntax#readme",
  "bugs": {
    "url": "https://github.com/rstackjs/rsbuild-plugin-check-syntax/issues"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "dev": "rslib -w",
    "lint": "rslint && prettier -c .",
    "lint:write": "rslint --fix && prettier -w .",
    "prepare": "simple-git-hooks",
    "test": "rstest",
    "bump": "npx bumpp"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run lint:write"
  },
  "dependencies": {
    "acorn": "^8.17.0",
    "browserslist-to-es-version": "^1.4.2",
    "htmlparser2": "12.0.0",
    "picocolors": "^1.1.1",
    "source-map": "^0.7.6"
  },
  "devDependencies": {
    "@rsbuild/core": "2.1.2",
    "@rslib/core": "^0.23.1",
    "@rslint/core": "^0.6.4",
    "@rspack/cli": "^2.1.2",
    "@rspack/core": "^2.1.2",
    "@rstest/core": "^0.10.6",
    "@types/node": "^24.13.2",
    "prettier": "^3.9.4",
    "rslog": "^2.1.3",
    "simple-git-hooks": "^2.13.1",
    "strip-ansi": "^7.2.0",
    "typescript": "6.0.3",
    "upath": "^3.0.7"
  },
  "peerDependencies": {
    "@rsbuild/core": "^1.0.0 || ^2.0.0"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.9.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
